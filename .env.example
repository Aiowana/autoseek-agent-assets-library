# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# GitHub Access
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repository
GITHUB_BRANCH=main

# Sync Settings
SYNC_INTERVAL=300
SYNC_BATCH_SIZE=100

# Logging
LOG_LEVEL=INFO

# Webhook Server
WEBHOOK_ENABLED=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
GITHUB_WEBHOOK_SECRET=your_secret_key_here
WEBHOOK_WORKERS=1
