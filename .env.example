# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# GitHub Access (Default Tenant)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repository
GITHUB_BRANCH=main

# Sync Settings
SYNC_INTERVAL=300
SYNC_BATCH_SIZE=100

# Logging
LOG_LEVEL=INFO

# Webhook Server
WEBHOOK_ENABLED=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
GITHUB_WEBHOOK_SECRET=your_secret_key_here
WEBHOOK_WORKERS=1

# ============================================================================
# Multi-Tenant Configuration (Optional)
# ============================================================================
# When using multi-tenant mode, each tenant needs its own credentials.
# These environment variables are referenced in tenants.yaml.

# Project Alpha
PROJ_ALPHA_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
PROJ_ALPHA_WEBHOOK_SECRET=alpha_secret_here

# Project Beta
PROJ_BETA_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
PROJ_BETA_WEBHOOK_SECRET=beta_secret_here

# User Alice
USER_ALICE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
USER_ALICE_WEBHOOK_SECRET=alice_secret_here

# Gitee Example
GITEE_TOKEN=your_gitee_token_here
GITEE_WEBHOOK_SECRET=gitee_secret_here
